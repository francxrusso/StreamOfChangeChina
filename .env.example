# Copy this file to .env.local for local development.
# Never commit real passwords, tokens, or private connection strings.

APP_URL=http://localhost:3000

# Supabase client values. The NEXT_PUBLIC values are safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only values. Never expose these in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
